{
    "name": "andreia/filament-recurrence",
    "description": "A Filament plugin for handling recurrence patterns with form fields, table columns, and infolist components",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andréia Bohner",
            "email": "andreiabohner@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0|^4.0",
        "illuminate/contracts": "^12.0|^13.0",
        "simshaun/recurr": "^5.0",
        "spatie/laravel-package-tools": "^1.16",
        "tapp/filament-timezone-field": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Andreia\\FilamentRecurrence\\": "src/",
            "Andreia\\FilamentRecurrence\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Andreia\\FilamentRecurrence\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andreia\\FilamentRecurrence\\FilamentRecurrenceServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
